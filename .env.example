# ─────────────────────────────────────────────────────────────
# AI Retail Trend Analyzer — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file to Git!
# ─────────────────────────────────────────────────────────────

# Groq API Key (required for chatbot)
# Get yours FREE at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Serper API Key (for real-time web search)
# Get yours FREE at: https://serper.dev/
SERPER_API_KEY=your-serper-api-key-here

# Flask Settings
FLASK_ENV=production
FLASK_DEBUG=false
PORT=5000
